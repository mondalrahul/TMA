extends partials/_layout

block append content
    .contact-page
        .contact-nav
            .container
                .wrapper
                    .contact-breadcrumb
                        ol.breadcrumb
                            li.breadcrumb-item
                                a(href='#') Home
                            li.breadcrumb-item.active Contact Us
                    .contact-share
                        a.share(href="#") Share on Facebook
                        a.print(href="#") Print Page
        .content-wrapper
            .container
                .row
                    .col-md-8
                        .contact-form
                            p.title Get in Touch
                            p.sub-title Fill in the form below and we will be in contact!
                            form.row(action="")
                                .form-group.col-md-6
                                    label Name #[span.required *]
                                    input(type="text" name="first_name")
                                    p First Name
                                .form-group.col-md-6
                                    label &nbsp;
                                    input(type="text" name="last_name")
                                    p Last Name
                                .form-group.col-md-6
                                    label Email Address #[span.required *]
                                    input(type="text" name="email")
                                .form-group.col-md-6
                                    label Contact No.
                                    input(type="text" name="phone")
                                .form-group.col-md-6
                                    label Choose A Subject #[span *]
                                    select(name="Subject")
                                        option(value="") General Question
                                .form-group.col-md-12
                                    label Message #[span.required *]
                                    textarea(name="message", rows="5")
                                .form-group.col-md-12
                                    button.button.button-highlight SEND MESSAGE
                    .col-md-4
                        .contact-info
                            p.title Contact Details
                            p.business-time #[span.underline Business Hours:] 9am to 9pm
                            p.contact-number
                                a(href="tel:+65 3163 1367") +65 3163 1367
                            p.address
                                span Republic of Singapore Yacht Club, 
                                span 52 West Coast Ferry Road,
                                span Singapore 126887
                            p.email
                                a(href="mailto:sales@tridentmarineasia.com") sales@tridentmarineasia.com
                            .map
                                img(src="../images/contact/map.jpg", alt="")

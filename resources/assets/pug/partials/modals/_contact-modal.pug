#contactEnquiryModal.contact-enquiry-modal.modal.fade(tabindex='-1', role='dialog', aria-labelledby='', aria-hidden='true')
    .modal-dialog.modal-lg(role='document')
        .modal-content
            .modal-body
                button(type="button" class="close" data-dismiss="modal" aria-label="Close")
                    span(aria-hidden="true") &times;
                .contact-form
                    p.title Get in Touch
                    p.sub-title Fill in the form below and we will be in contact!
                    form.row(action="")
                        .form-group.col-md-6
                            label Name #[span.required *]
                            input(type="text" name="first_name" required)
                            p First Name
                        .form-group.col-md-6
                            label &nbsp;
                            input(type="text" name="last_name")
                            p Last Name
                        .form-group.col-md-6
                            label Email Address #[span.required *]
                            input(type="text" name="email" required)
                        .form-group.col-md-6
                            label Contact No.
                            input(type="text" name="phone")
                        .form-group.col-md-6
                            label Choose A Subject #[span *]
                            select(name="Subject" required)
                                option(value="") General Question
                        .form-group.col-md-12
                            label Message #[span.required *]
                            textarea(name="message", rows="5" required)
                        .form-group.col-md-12
                            button.button.button-highlight SEND MESSAGE